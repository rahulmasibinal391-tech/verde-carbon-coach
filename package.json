{
  "name": "verde-carbon-coach",
  "version": "1.0.0",
  "description": "Verde Carbon Coach — Hackathon Upgrade",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "node server/server.js",
    "dev:client": "vite frontend",
    "build": "vite build frontend --outDir ../dist",
    "preview": "vite preview frontend",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint \"frontend/src/**/*.js\" \"server/**/*.js\"",
    "format": "prettier --write \"frontend/src/**/*.js\" \"server/**/*.js\" \"frontend/**/*.html\" \"frontend/**/*.css\""
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@vitest/coverage-v8": "^1.3.1",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.2.5",
    "vite": "^5.1.4",
    "vitest": "^1.3.1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0"
  }
}
